{
    "name": "gollumsf/rest-bundle",
    "type": "symfony-bundle",
    "description": "Very simple REST Api implementation",
    "keywords" : [
        "api",
        "simple",
        "rest",
        "gollumsf"
    ],
    "homepage": "https://github.com/GollumSF/rest-bundle",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Damien Duboeuf",
            "email": "smeagolworms4@gmail.com"
        }
    ],
    "support" : {
        "email": "smeagolworms4@gmail.com",
        "wiki": "https://github.com/GollumSF/rest-bundle/blob/master/README.md"
    },
    "require" : {
        "php": ">=8.2",
        "gollumsf/controller-action-extractor-bundle": "^1.0|^2.0",
        "doctrine/orm": "^2.14|^3.0",
        "doctrine/doctrine-bundle": "^2.7|^3.0",
        "symfony/config": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/event-dispatcher": "^6.4|^7.0|^8.0",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "symfony/http-kernel": "^6.4|^7.0|^8.0",
        "symfony/property-access": "^6.4|^7.0|^8.0",
        "symfony/property-info": "^6.4|^7.0|^8.0",
        "symfony/security-bundle": "^6.4|^7.0|^8.0",
        "symfony/serializer": "^6.4|^7.0|^8.0",
        "symfony/validator": "^6.4|^7.0|^8.0",
        "symfony/yaml": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.4|^4.0",
        "gollumsf/reflection-property-test": "^1.0",
        "phpunit/phpunit": "^11.0",
        "matthiasnoback/symfony-dependency-injection-test": "^4.1|^5.0|^6.0|^7.0",
        "nyholm/symfony-bundle-test": "^3.0",
        "symfony/browser-kit": "^6.4|^7.0|^8.0",
        "gollumsf/entity-relation-setter": "^3.0",
        "monolog/monolog": "^3.0",
        "masterminds/html5": "^2.7",
        "symfony/var-exporter": "^6.4|^7.0|^8.0"
    },
    "autoload" : {
        "psr-4" : {
            "GollumSF\\RestBundle\\" : "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\GollumSF\\RestBundle\\" : "tests/"
        }
    }
}
